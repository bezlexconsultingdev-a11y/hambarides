# Supabase (required for admin login and data)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: in dev, skip login and show dashboard as mock admin (UI only; data may be empty due to RLS)
# VITE_DEV_SKIP_LOGIN=true

# Hamba API (required for admin API + Push Notifications page — same base as mobile apps)
# VITE_API_BASE=http://localhost:5000/api
# VITE_API_BASE=https://your-backend.onrender.com/api

# Optional: same value as ADMIN_NOTIFICATIONS_API_KEY on hamba-rides-backend; allows broadcast/history
# without relying on JWT user_type=admin (e.g. some CI or emergency sends).
# VITE_ADMIN_NOTIFICATIONS_API_KEY=

# Optional: Mapbox for map features
# VITE_MAPBOX_ACCESS_TOKEN=pk....
